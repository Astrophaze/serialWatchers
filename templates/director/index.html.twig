{% extends 'base.html.twig' %}

{% block title %}Tous les réalisateurs
{% endblock %}

{% block body %}

	<div class="container">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1 class="text-center text-muted">Liste des réalisateurs</h1>
			<a class="btn btn-secondary shadow-sm" href="{{path('app_movie')}}">Voir les films</a>
			<a class="btn btn-info shadow-sm" href="{{path('app_director_new')}}">Ajouter un réalisateur</a>
		</div>
		<div class="row">
			{% for director in directors %}
				<div class="col-md-4">
					<div class="card mb-4 p-3">
						<div class="d-flex justify-content-between">
						<h5 class="">{{ director.firstName }}
							{{ director.lastName }}</h5>
						<p>Nombre de films : <strong><em>{{ filmCount[director.id] }}</em></strong></p>
						</div>
						<a class="btn btn-info shadow-sm" href="{{path('app_director_detail', {id: director.id}) }}">Plus de détails</a>
					</div>
				</div>
			{% endfor %}
		</div>
	</div>
{% endblock %}
